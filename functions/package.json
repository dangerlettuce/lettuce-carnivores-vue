{
  "name": "functions",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "debug": "npm run build && firebase emulators:start --only functions --inspect-functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "preinstall": "npx only-allow pnpm",
    "test": "firebase emulators:start --inspect-functions",
    "emulate": "firebase emulators:start --inspect-functions"
  },
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/functions-framework": "^3.5.1",
    "@types/mjml": "^4.7.4",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.6",
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^7.2.2",
    "mjml": "^4.18.0",
    "nodemailer": "^7.0.13",
    "qs": "^6.15.0",
    "stripe": "^17.7.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/xml2js": "^0.4.14",
    "firebase-functions-test": "^3.4.1",
    "isolate-package": "^1.29.0",
    "typescript": "^6.0.2"
  },
  "private": true
}
